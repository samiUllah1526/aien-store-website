# Backend API URL (for product listing, checkout, auth). Required. No trailing slash.
# In production, must be set to your API URL (e.g. https://api.yoursite.com).
PUBLIC_API_URL=http://localhost:3000

# Site URL (no trailing slash). Required for SEO in production (canonical, og:url).
# PUBLIC_SITE_URL=https://yoursite.com

# Hero video: YouTube, Vimeo, or direct mp4/webm URL
# Examples: https://youtu.be/VIDEO_ID, https://vimeo.com/123456, /videos/hero.mp4
PUBLIC_HERO_VIDEO_URL=

# Hero poster image (optional). Any public image URL.
PUBLIC_HERO_VIDEO_POSTER=

# Hero image carousel: edit main-website/src/config.ts — heroSlides array.
# Shape: [ { src: string, alt?: string }, ... ]. When heroSlides.length > 0, carousel is used instead of video hero.

# Brand name (default: Aien)
# PUBLIC_BRAND_NAME=Aien

# Meta descriptions (optional; see site.config.example for full list)
# PUBLIC_META_DESCRIPTION=Aien (ع) is a contemporary streetwear label rooted in Ishq—blending Sufi philosophy, old cultural heritage, and timeless storytelling into modern baggy silhouettes. Crafted with premium fabrics, each piece reflects love, history, and identity in every thread.

# Favicon path (default: /favicon.svg) when no favicon is uploaded in Admin → Settings → General.
# PUBLIC_FAVICON=/favicon.svg

# Theme localStorage key (default: aien-theme)
# PUBLIC_THEME_STORAGE_KEY=aien-theme
