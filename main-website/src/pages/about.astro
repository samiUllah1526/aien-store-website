---
/**
 * About: content and optional full-bleed banner from site settings (admin-editable).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import CollectionsHero from '../components/shop/CollectionsHero.astro';
import { aboutMetaDescription, brandName } from '../config';
import { getPublicSettings } from '../lib/settings';
import { buildImageUrl, buildImageSrcSet, IMAGE_PRESETS } from '../lib/buildImageUrl';

const BANNER_SRCSET_WIDTHS = [480, 768, 1200, 1920] as const;
const MOBILE_BANNER_SRCSET_WIDTHS = [480, 640, 800] as const;

const settings = await getPublicSettings();
const a = settings.about;

const aboutTitle = (a.title?.trim() || brandName) as string;
const aboutSubtitle = (a.subtitle?.trim() || 'Cultural-art collective. Poetry on fabric.') as string;
const aboutContent = (a.content?.trim() || '') as string;

const bannerRaw = a.bannerImageUrl?.trim();
const bannerSrc = bannerRaw ? buildImageUrl(bannerRaw, IMAGE_PRESETS.heroBanner) : '';
const bannerSrcSet = bannerRaw
  ? buildImageSrcSet(bannerRaw, BANNER_SRCSET_WIDTHS, {
      crop: 'fill',
      quality: 'auto',
      format: 'auto',
    })
  : '';
const mobileBannerSrc = bannerRaw
  ? buildImageUrl(bannerRaw, IMAGE_PRESETS.heroBannerMobile)
  : '';
const mobileBannerSrcSet = bannerRaw
  ? buildImageSrcSet(bannerRaw, MOBILE_BANNER_SRCSET_WIDTHS, {
      aspectRatio: '4:5',
      crop: 'fill',
      quality: 'auto',
      format: 'auto',
    })
  : '';

// Fallback static content if no HTML from settings
const fallbackContent = `
  <p>We make garments that hold silence. Where poetry meets fabric, and loss meets wear.</p>
  <p>Each piece carries a verse — in Nastaliq script, like breath on paper. We are not a hype streetwear brand.
  We are a cultural-art collective. The words come first. The wear follows.</p>
  <p>Hoodies and oversized shirts for those who carry the weight of a single word. Streetwear that
  doesn't shout — it speaks quietly, in the space between longing and letting go.</p>
  <p class="urdu-text font-urdu text-2xl md:text-3xl text-soft-charcoal dark:text-off-white text-right leading-loose mt-16 py-10 border-t border-b border-ash/20">خاموشی میں واپس آؤ</p>
  <p class="text-ash text-sm italic">Return to silence.</p>
  <p>Thank you for wearing the verse with us.</p>
`;
const displayContent = aboutContent.trim() ? aboutContent : fallbackContent;
---

<BaseLayout title={`About — ${brandName}`} description={aboutMetaDescription}>
  {bannerSrc ? (
    <CollectionsHero
      title={aboutTitle}
      eyebrow={`${brandName.toUpperCase()} — STORY`}
      bannerSrc={bannerSrc}
      bannerSrcSet={bannerSrcSet}
      mobileBannerSrc={mobileBannerSrc}
      mobileBannerSrcSet={mobileBannerSrcSet}
      prominence="primary"
      lede={aboutSubtitle}
      singleLineTitle
      ariaLabel="About"
    />
  ) : null}

  <article class="max-w-prose mx-auto px-4 sm:px-6 py-16 md:py-24">
    {!bannerSrc && (
      <header class="mb-14">
        <h1 class="font-display text-3xl md:text-4xl text-soft-charcoal dark:text-off-white leading-tight">
          {aboutTitle}
        </h1>
        <p class="mt-4 text-lg text-ash font-display">
          {aboutSubtitle}
        </p>
      </header>
    )}

    <div class="space-y-10 text-soft-charcoal/90 dark:text-off-white/90 leading-relaxed about-content" set:html={displayContent} />
  </article>
</BaseLayout>
