---
/**
 * Checkout page — editorial AIEN shell.
 * Matches the cart page's layout: max-w-site, generous gutters, no inner heading
 * (CheckoutForm renders its own editorial header).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import CheckoutForm from '../components/checkout/CheckoutForm';
import { brandName, checkoutMetaDescription } from '../config';
---

<BaseLayout title={`Checkout — ${brandName}`} description={checkoutMetaDescription}>
  <main class="max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 py-16 md:py-24">
    <CheckoutForm client:load />
  </main>
</BaseLayout>
