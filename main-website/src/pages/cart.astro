---
/**
 * Cart page (UI only): minimal list of items when user lands on /cart.
 * For full cart UI we rely on the cart sidebar from the shell; this page can show same content or a message.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import CartPage from '../components/cart/CartPage';
import { brandName, cartMetaDescription } from '../config';
---

<BaseLayout title={`Cart — ${brandName}`} description={cartMetaDescription}>
  <main class="max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 py-16 md:py-24">
    <CartPage client:load />
  </main>
</BaseLayout>
