---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthLayout from '../components/auth/AuthLayout.astro';
import ResetPasswordForm from '../components/auth/ResetPasswordForm';
import { brandName, resetPasswordMetaDescription } from '../config';
---

<BaseLayout title={`Reset password — ${brandName}`} description={resetPasswordMetaDescription}>
  <AuthLayout
    title="Reset password"
    eyebrow="ACCOUNT"
    lede="Choose a new password for your account."
  >
    <ResetPasswordForm client:load />
  </AuthLayout>
</BaseLayout>
