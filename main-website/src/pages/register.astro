---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthLayout from '../components/auth/AuthLayout.astro';
import RegisterForm from '../components/auth/RegisterForm';
import { brandName, registerMetaDescription } from '../config';
---

<BaseLayout title={`Sign up — ${brandName}`} description={registerMetaDescription}>
  <AuthLayout
    title="Create account"
    eyebrow="ACCOUNT"
    lede="One account for orders, returns, and saved pieces."
  >
    <RegisterForm client:load />
  </AuthLayout>
</BaseLayout>
