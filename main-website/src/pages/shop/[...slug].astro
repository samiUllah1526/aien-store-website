---
/**
 * Product detail only: `/shop/:productSlug`.
 * Category listings live under `/shop/category/:categorySlug`.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductDetailSection from '../../components/product/ProductDetailSection';
import AnimatedUrduVerse from '../../components/AnimatedUrduVerse';
import { formatMoney } from '../../lib/formatMoney';
import { storeApiBaseUrl, brandName, siteUrl } from '../../config';
import { stripHtml } from '../../lib/stripHtml';
import { buildImageUrl, toAbsoluteUrl, IMAGE_PRESETS } from '../../lib/buildImageUrl';

export async function getStaticPaths() {
  const limit = 100;
  const slugs: string[] = [];
  try {
    let page = 1;
    let hasMore = true;
    while (hasMore) {
      const url = `${storeApiBaseUrl}/products?page=${page}&limit=${limit}&sortBy=slug&sortOrder=asc`;
      const res = await fetch(url);
      const json = await res.json();
      if (!res.ok || !json.success || !Array.isArray(json.data)) break;
      const pageSlugs = json.data.map((p: { slug: string }) => p.slug).filter(Boolean);
      slugs.push(...pageSlugs);
      const total = json.meta?.total ?? 0;
      hasMore = slugs.length < total && pageSlugs.length === limit;
      page += 1;
    }
  } catch (err) {
    console.error('[getStaticPaths] products error:', err);
  }

  return slugs.map((slug: string) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/shop');
}

let product: {
  id: string;
  name: string;
  slug: string;
  description: string | null;
  price: number;
  currency: string;
  /** Main carousel slide src (1200×1600 Cloudinary variant). */
  image: string;
  /** Main carousel slides (1200×1600 Cloudinary variants). */
  images: string[];
  /** Parallel array of 200×200 thumbnail variants for the carousel strip. */
  thumbnails: string[];
  variants: Array<{
    id: string;
    color: string;
    size: string;
    stockQuantity: number;
    priceOverrideCents?: number | null;
    isActive: boolean;
    image?: string;
    images?: string[];
    /** 200×200 variants of `images`; same length and order. */
    thumbnails?: string[];
  }>;
  sizes?: string[];
  inStock: boolean;
  urduVerse?: string | null;
  urduVerseTransliteration?: string | null;
  categories?: Array<{ name: string; slug: string }>;
} | null = null;

try {
  const productUrl = `${storeApiBaseUrl}/products/slug/${encodeURIComponent(slug)}`;
  const res = await fetch(productUrl);
  const json = await res.json();
  if (res.ok && json.success && json.data) {
    const p = json.data;
    // Apply transforms from the *raw* URL each time so we don't accidentally
    // chain Cloudinary transforms (e.g. building a 1200×1600 then re-cropping
    // it to 200×200 would upscale the cropped intermediate, not the source).
    const rawImage = (p.image as string) ?? '';
    const rawImages = Array.isArray(p.images) ? (p.images as string[]) : [];
    const image = buildImageUrl(rawImage, IMAGE_PRESETS.productDetail);
    const images = rawImages
      .map((img) => buildImageUrl(img, IMAGE_PRESETS.productDetail))
      .filter(Boolean);
    const variants = (Array.isArray(p.variants) ? p.variants : []).map(
      (variant: { image?: string; images?: string[] } & Record<string, unknown>) => {
        const rawV = (variant.image as string) ?? '';
        const rawVImages = Array.isArray(variant.images) ? (variant.images as string[]) : [];
        const variantImage = buildImageUrl(rawV, IMAGE_PRESETS.productDetail);
        const variantImages = rawVImages.length
          ? rawVImages
              .map((img) => buildImageUrl(img, IMAGE_PRESETS.productDetail))
              .filter(Boolean)
          : variantImage
            ? [variantImage]
            : [];
        const variantThumbnails = rawVImages.length
          ? rawVImages
              .map((img) => buildImageUrl(img, IMAGE_PRESETS.productThumb))
              .filter(Boolean)
          : rawV
            ? [buildImageUrl(rawV, IMAGE_PRESETS.productThumb)].filter(Boolean)
            : [];
        return {
          ...variant,
          image: variantImage,
          images: variantImages,
          thumbnails: variantThumbnails,
        };
      },
    );
    product = {
      id: p.id,
      name: p.name,
      slug: p.slug,
      description: p.description ?? null,
      price: p.price,
      currency: p.currency,
      image,
      images: images.length > 0 ? images : image ? [image] : [],
      thumbnails: rawImages.length
        ? rawImages.map((img) => buildImageUrl(img, IMAGE_PRESETS.productThumb)).filter(Boolean)
        : rawImage
          ? [buildImageUrl(rawImage, IMAGE_PRESETS.productThumb)].filter(Boolean)
          : [],
      variants,
      sizes: p.sizes,
      inStock: p.inStock !== false,
      urduVerse: p.urduVerse ?? null,
      urduVerseTransliteration: p.urduVerseTransliteration ?? null,
      categories: p.categories ?? [],
    };
  }
} catch (err) {
  console.error('[product page] fetch error:', err);
}

if (!product) {
  return Astro.redirect('/shop');
}

const defaultVariant =
  product.variants.find((variant) => variant.isActive && variant.stockQuantity > 0) ??
  product.variants.find((variant) => variant.isActive) ??
  null;
const defaultVariantImages = defaultVariant?.images?.length
  ? defaultVariant.images
  : defaultVariant?.image
    ? [defaultVariant.image]
    : [];
const displayImages =
  defaultVariantImages.length > 0
    ? [...defaultVariantImages, ...product.images.filter((img) => !defaultVariantImages.includes(img))]
    : product.images;

const canonicalUrl = siteUrl ? `${siteUrl}/shop/${product.slug}` : undefined;
const rawOgImage = displayImages?.[0] ?? product.image;
const ogImageAbs = rawOgImage
  ? toAbsoluteUrl(buildImageUrl(rawOgImage, IMAGE_PRESETS.ogImage), siteUrl || storeApiBaseUrl)
  : undefined;

const productImages = (displayImages ?? (product.image ? [product.image] : [])).map((img: string) =>
  toAbsoluteUrl(img, siteUrl || storeApiBaseUrl),
);
// Meta description and JSON-LD must always be plain text. If/when product
// descriptions move to TipTap rich-text, stripping here keeps these channels
// safe; the on-page body below is the only place that will need to switch to
// rich rendering at that point.
const productDescriptionPlain = stripHtml(product.description) || undefined;
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: productDescriptionPlain,
  image: productImages.length ? productImages : undefined,
  offers: {
    '@type': 'Offer',
    price: product.price / 100,
    priceCurrency: product.currency,
    availability: product.inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
  ...(canonicalUrl && { url: canonicalUrl }),
};
---

<BaseLayout
  title={`${product.name} — ${brandName}`}
  description={productDescriptionPlain}
  image={ogImageAbs}
  canonical={canonicalUrl}
  jsonLd={productJsonLd}
>
  <article class="max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 py-12 md:py-16">
    <nav
      class="flex mb-12 font-sans text-label-caps text-on-surface-variant gap-2 uppercase"
      aria-label="Breadcrumb"
    >
      <a class="hover:text-on-background" href="/">Home</a>
      <span aria-hidden>/</span>
      {product.categories?.[0] ? (
        <>
          <a
            class="hover:text-on-background"
            href={`/shop/category/${product.categories[0].slug}`}
          >{product.categories[0].name}</a>
          <span aria-hidden>/</span>
        </>
      ) : (
        <>
          <a class="hover:text-on-background" href="/shop">Shop</a>
          <span aria-hidden>/</span>
        </>
      )}
      <span class="text-on-background truncate max-w-[60vw]">{product.name}</span>
    </nav>

    <ProductDetailSection
      client:load
      productId={product.id}
      name={product.name}
      slug={product.slug}
      price={product.price}
      currency={product.currency}
      image={product.image}
      images={product.images}
      thumbnails={product.thumbnails}
      variants={product.variants}
      inStock={product.inStock}
    >
      {product.categories?.length ? (
        <p class="font-sans text-label-caps text-on-surface-variant uppercase tracking-widest mb-2">
          {product.categories.map((c) => c.name).join(' / ')}
        </p>
      ) : null}

      <h1 class="font-serif text-h2-editorial text-on-background mb-4">
        {product.name}
      </h1>

      <p class="font-body-lg text-secondary mb-8">
        {formatMoney(product.price, product.currency)}
      </p>

      {product.urduVerse && (
        <div class="mb-8">
          <AnimatedUrduVerse
            client:load
            verse={product.urduVerse}
            transliteration={product.urduVerseTransliteration}
          />
        </div>
      )}

      {/*
        NOTE: product description is currently plain text. When products migrate
        to a TipTap rich-text editor (like categories), switch this to render
        via `set:html` with the `aien-rich-text` class:

          <div class="aien-rich-text font-body-md text-on-surface-variant"
               set:html={product.description} />

        Keep `productDescriptionPlain` (above) for meta description and JSON-LD.
      */}
      {product.description && (
        <div class="border-t border-outline-variant pt-8 mb-2">
          <p class="font-body-md text-on-surface-variant leading-relaxed">
            {product.description}
          </p>
        </div>
      )}
    </ProductDetailSection>
  </article>
</BaseLayout>
