---
/**
 * Shop landing — products + landing banner fetched at build time.
 * Editorial AIEN treatment: title overlaid hero, sticky filter rail in grid.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopGrid from '../../components/shop/ShopGrid';
import { brandName, shopMetaDescription, storeApiBaseUrl } from '../../config';
import { fetchAllProductsAtBuild } from '../../lib/fetchStoreProductsBuild';

const DEFAULT_BANNER_IMAGE =
  'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=80&auto=format&fit=crop';
const DEFAULT_SHOP_DESCRIPTION =
  'Refined essentials for the modern silhouette. Our core collection emphasizes structured drapery and premium technical fabrics.';

function toFullImageUrl(url: string): string {
  if (!url) return '';
  return url.startsWith('http') ? url : `${storeApiBaseUrl}${url.startsWith('/') ? '' : '/'}${url}`;
}

let bannerImage = DEFAULT_BANNER_IMAGE;
let shopDescription = DEFAULT_SHOP_DESCRIPTION;
try {
  const res = await fetch(`${storeApiBaseUrl}/categories/landing`);
  const json = await res.json();
  if (res.ok && json.success && Array.isArray(json.data) && json.data.length > 0) {
    const cat = json.data[0] as { bannerImageUrl?: string | null; description?: string | null };
    const raw = cat.bannerImageUrl?.trim();
    if (raw) bannerImage = toFullImageUrl(raw);
    const desc = cat.description?.trim();
    if (desc) shopDescription = desc;
  }
} catch (err) {
  console.error('[shop index] landing categories error:', err);
}

let products: Awaited<ReturnType<typeof fetchAllProductsAtBuild>> = [];
try {
  products = await fetchAllProductsAtBuild(storeApiBaseUrl);
} catch (err) {
  console.error('[shop index] products error:', err);
}
---

<BaseLayout title={`Shop — ${brandName}`} description={shopMetaDescription}>
  <section
    class="relative w-full h-[44vh] min-h-[320px] max-h-[520px] overflow-hidden bg-surface-container-low"
    aria-label="Shop banner"
  >
    <img
      src={bannerImage}
      alt=""
      class="w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative h-full max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 flex flex-col justify-end pb-16">
      <span class="font-sans text-label-caps text-white mb-6">{brandName.toUpperCase()} — COLLECTIONS</span>
      <h1 class="font-serif text-h1-display text-white max-w-3xl">Core Collection</h1>
    </div>
  </section>

  <main class="max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 pt-16 md:pt-20 pb-section-gap">
    <header class="mb-12 max-w-2xl">
      <p class="font-body-lg text-on-surface-variant">{shopDescription}</p>
    </header>
    <ShopGrid products={products} client:load />
  </main>
</BaseLayout>
