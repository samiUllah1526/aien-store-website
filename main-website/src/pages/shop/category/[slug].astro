---
/**
 * Category listing: `/shop/category/:categorySlug` — products in that category only.
 * Product detail pages live at `/shop/:productSlug` (separate route).
 *
 * Editorial AIEN treatment: hero banner with overlaid title and description,
 * filterable grid below.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShopGrid from '../../../components/shop/ShopGrid';
import CategoryIntro from '../../../components/shop/CategoryIntro.astro';
import { storeApiBaseUrl, brandName, siteUrl } from '../../../config';
import { fetchAllProductsAtBuild } from '../../../lib/fetchStoreProductsBuild';
import { stripHtml } from '../../../lib/stripHtml';
import { buildImageUrl, buildImageSrcSet, IMAGE_PRESETS } from '../../../lib/buildImageUrl';

const BANNER_SRCSET_WIDTHS = [480, 768, 1200, 1920] as const;

type StoreCategory = {
  id: string;
  name: string;
  slug: string;
  /** Rich-text HTML from the admin TipTap editor; legacy plain text renders identically. */
  description: string | null;
  /** Bullet list shown beside the description on the storefront category page. */
  highlights?: string[];
  bannerImageUrl: string | null;
};

export async function getStaticPaths() {
  let categories: StoreCategory[] = [];
  try {
    const res = await fetch(`${storeApiBaseUrl}/categories`);
    const json = await res.json();
    if (res.ok && json.success && Array.isArray(json.data)) {
      categories = json.data as StoreCategory[];
    }
  } catch (err) {
    console.error('[getStaticPaths category] categories error:', err);
  }

  return categories
    .filter((c) => c.slug?.trim())
    .map((cat) => ({
      params: { slug: cat.slug },
      props: { category: cat },
    }));
}

const { category } = Astro.props as { category: StoreCategory };

const DEFAULT_CATEGORY_BANNER =
  'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=1920&q=80&auto=format&fit=crop';

let products: Awaited<ReturnType<typeof fetchAllProductsAtBuild>> = [];
try {
  products = await fetchAllProductsAtBuild(storeApiBaseUrl, { categorySlug: category.slug });
} catch (err) {
  console.error('[category page] fetch error:', err);
}

const bannerRaw = category.bannerImageUrl?.trim();
const bannerImage = bannerRaw
  ? buildImageUrl(bannerRaw, IMAGE_PRESETS.heroBanner)
  : DEFAULT_CATEGORY_BANNER;
const bannerSrcSet = bannerRaw
  ? buildImageSrcSet(bannerRaw, BANNER_SRCSET_WIDTHS, {
      crop: 'fill',
      quality: 'auto',
      format: 'auto',
    })
  : '';
const descriptionHtml = category.description?.trim() ?? '';
const highlights = (category.highlights ?? []).map((h) => h.trim()).filter(Boolean);
// SEO meta description must be plain text, even when the admin entered rich text via TipTap.
const metaDescription =
  stripHtml(descriptionHtml).slice(0, 160) ||
  `Browse ${category.name} — cultural-art streetwear with poetry on fabric.`;
const canonicalUrl = siteUrl ? `${siteUrl}/shop/category/${category.slug}` : undefined;
const ogImageAbs =
  bannerImage &&
  (bannerImage.startsWith('http') ? bannerImage : `${siteUrl || storeApiBaseUrl}${bannerImage.startsWith('/') ? '' : '/'}${bannerImage}`);

const categoryJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category.name,
  description: metaDescription,
  ...(canonicalUrl && { url: canonicalUrl }),
};
---

<BaseLayout
  title={`${category.name} — ${brandName}`}
  description={metaDescription}
  image={ogImageAbs}
  canonical={canonicalUrl}
  jsonLd={categoryJsonLd}
>
  <section
    class="relative w-full h-[32vh] sm:h-[40vh] md:h-[44vh] min-h-[220px] sm:min-h-[280px] md:min-h-[320px] max-h-[520px] overflow-hidden bg-surface-container-low"
    aria-label={`${category.name} banner`}
  >
    <img
      src={bannerImage}
      srcset={bannerSrcSet || undefined}
      sizes="100vw"
      alt=""
      class="w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative h-full max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 flex flex-col justify-end pb-16">
      <span class="font-sans text-label-caps text-white mb-6">
        {brandName.toUpperCase()} — COLLECTIONS
      </span>
      <h1 class="font-serif text-h1-display text-white max-w-3xl">{category.name}</h1>
    </div>
  </section>

  <main class="max-w-site mx-auto px-4 sm:px-6 md:px-10 lg:px-16 pt-16 md:pt-20 pb-section-gap">
    <CategoryIntro
      categoryName={category.name}
      description={descriptionHtml}
      highlights={highlights}
      fallbackText={`Browse ${category.name} — cultural-art streetwear with poetry on fabric.`}
    />
    <ShopGrid client:load products={products} />
  </main>
</BaseLayout>
