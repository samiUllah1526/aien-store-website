---
/**
 * Home: static shell. Hero carousel from admin settings when available.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage, { type LandingCategory, type Product } from '../components/home/HomePage';
import {
  apiBaseUrl,
  brandName,
  defaultMetaDescription,
  heroVideoUrl,
  heroVideoPoster,
  heroSlides,
  storeApiBaseUrl,
} from '../config';
import { getPublicSettings, type PublicSettings } from '../lib/settings';
import { buildImageUrl, IMAGE_PRESETS } from '../lib/buildImageUrl';

function absoluteMediaUrl(apiRoot: string, pathOrUrl: string | null | undefined): string | undefined {
  if (!pathOrUrl?.trim()) return undefined;
  const p = pathOrUrl.trim();
  if (p.startsWith('http')) return p;
  return `${apiRoot}/media/file/${p.replace(/^\//, '')}`;
}

/** Homepage `ClothingStore`-style JSON-LD from public settings (Admin SEO + Store structured data). */
function buildHomepageStoreJsonLd(settings: PublicSettings, apiRoot: string): Record<string, unknown> | null {
  const seo = settings.seo;
  const bus = settings.business;
  const site = (seo.siteUrl || '').replace(/\/+$/, '');
  if (!site) return null;

  const name = seo.siteTitle?.trim() || brandName;
  const description = seo.defaultDescription?.trim() || defaultMetaDescription;
  const type = (bus.schemaOrgType?.trim() || 'ClothingStore').slice(0, 80);

  const out: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': type,
    name,
    url: site,
    description,
  };

  const logo = absoluteMediaUrl(apiRoot, settings.logoPath);
  if (logo) out.logo = logo;

  const og = seo.ogImageDefault?.trim();
  if (og) {
    out.image = og.startsWith('http') ? og : `${site}${og.startsWith('/') ? '' : '/'}${og}`;
  }

  const c = bus.addressCountry?.trim();
  const loc = bus.addressLocality?.trim();
  const reg = bus.addressRegion?.trim();
  if (c || loc || reg) {
    out.address = {
      '@type': 'PostalAddress',
      ...(c ? { addressCountry: c } : {}),
      ...(loc ? { addressLocality: loc } : {}),
      ...(reg ? { addressRegion: reg } : {}),
    };
  }

  const tel = bus.telephone?.trim();
  if (tel) {
    out.contactPoint = {
      '@type': 'ContactPoint',
      telephone: tel,
      contactType: (bus.contactType?.trim() || 'customer service').slice(0, 80),
    };
  }

  return out;
}

const baseUrl = storeApiBaseUrl.replace(/\/$/, '');

function mapProduct(p: Record<string, unknown>): Product {
  const rawVariants = Array.isArray(p.variants) ? (p.variants as Array<Record<string, unknown>>) : [];
  const variants = rawVariants.map((v) => ({
    id: String(v.id ?? ''),
    color: String(v.color ?? ''),
    size: String(v.size ?? ''),
    stockQuantity: Number(v.stockQuantity ?? 0),
    priceOverrideCents: v.priceOverrideCents != null ? Number(v.priceOverrideCents) : null,
    isActive: v.isActive !== false,
    image: typeof v.image === 'string' ? buildImageUrl(v.image, IMAGE_PRESETS.productCard) : '',
    images: Array.isArray(v.images)
      ? (v.images as string[])
          .map((img) => buildImageUrl(img, IMAGE_PRESETS.productCard))
          .filter(Boolean)
      : [],
  }));
  const variantImage = variants.find((v) => v.image)?.image ?? '';
  const img = (p.image as string) || variantImage;
  const price = Number(p.price);
  const salePrice = p.salePrice != null ? Number(p.salePrice) : null;
  const originalPrice = p.originalPrice != null ? Number(p.originalPrice) : null;
  const legacyCompareAt = p.compareAtPrice != null ? Number(p.compareAtPrice) : null;
  const compareAt = originalPrice ?? (legacyCompareAt != null && !Number.isNaN(legacyCompareAt) ? legacyCompareAt : null);
  const effectivePrice = salePrice ?? price;
  return {
    id: String(p.id),
    slug: String(p.slug),
    name: String(p.name),
    price: effectivePrice,
    currency: String(p.currency ?? 'PKR'),
    image: buildImageUrl(img, IMAGE_PRESETS.productCard),
    variants,
    inStock: p.inStock !== false,
    urduVerse: (p.urduVerse as string | null) ?? null,
    urduVerseTransliteration: (p.urduVerseTransliteration as string | null) ?? null,
    description: (p.description as string | null) ?? null,
    sizes: (p.sizes as string[] | undefined) ?? undefined,
    compareAtPrice: compareAt,
    saleBadgeText: (p.saleBadgeText as string | null) ?? null,
  };
}

async function loadHomeCatalog() {
  try {
    const [allRes, landingRes] = await Promise.all([
      fetch(`${baseUrl}/products`),
      fetch(`${baseUrl}/categories/landing`),
    ]);

    const allJson = await allRes.json().catch(() => ({}));
    const shopAll: Product[] = allRes.ok && allJson?.success && Array.isArray(allJson.data)
      ? allJson.data.map((p: Record<string, unknown>) => mapProduct(p))
      : [];
    const landingJson = await landingRes.json().catch(() => ({}));
    const landingCategories: LandingCategory[] = landingRes.ok && landingJson?.success && Array.isArray(landingJson.data)
      ? landingJson.data
      : [];

    const productsBySlug: Record<string, Product[]> = {};
    if (landingCategories.length > 0) {
      const productResList = await Promise.all(
        landingCategories.map((c) => fetch(`${baseUrl}/products?category=${encodeURIComponent(c.slug)}&limit=12`)),
      );

      for (let i = 0; i < landingCategories.length; i++) {
        const res = productResList[i];
        const json = await res.json().catch(() => ({}));
        productsBySlug[landingCategories[i].slug] = res.ok && json?.success && Array.isArray(json.data)
          ? json.data.map((p: Record<string, unknown>) => mapProduct(p))
          : [];
      }
    }

    return { shopAll, landingCategories, productsBySlug };
  } catch {
    return {
      shopAll: [] as Product[],
      landingCategories: [] as LandingCategory[],
      productsBySlug: {} as Record<string, Product[]>,
    };
  }
}

const settings = await getPublicSettings();
const heroSlidesFromApi = settings.hero?.slides?.length ? settings.hero.slides : [];
const heroSlidesToUse = heroSlidesFromApi.length > 0 ? heroSlidesFromApi : heroSlides;
const { shopAll, landingCategories, productsBySlug } = await loadHomeCatalog();

const apiRoot = apiBaseUrl.replace(/\/$/, '');
const clothingStoreJsonLd = buildHomepageStoreJsonLd(settings, apiRoot);
---

<BaseLayout title={brandName} description={defaultMetaDescription} jsonLd={clothingStoreJsonLd ?? undefined}>
  <HomePage
    client:load
    videoSrc={heroVideoUrl}
    videoPoster={heroVideoPoster}
    heroSlides={heroSlidesToUse}
    shopAll={shopAll}
    landingCategories={landingCategories}
    productsBySlug={productsBySlug}
  />
</BaseLayout>
