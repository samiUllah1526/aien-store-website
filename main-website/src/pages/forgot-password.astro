---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthLayout from '../components/auth/AuthLayout.astro';
import ForgotPasswordForm from '../components/auth/ForgotPasswordForm';
import { brandName, forgotPasswordMetaDescription } from '../config';
---

<BaseLayout title={`Forgot password — ${brandName}`} description={forgotPasswordMetaDescription}>
  <AuthLayout
    title="Forgot password"
    eyebrow="ACCOUNT"
    lede="Enter your email and we'll send you a link to reset it."
  >
    <ForgotPasswordForm client:load />
  </AuthLayout>
</BaseLayout>
