---
/**
 * Category page editorial intro block.
 *
 * Layout:
 * - Description renders full-width above as a single column.
 * - Highlights (when present) render below as a compact 2-column grid with a
 *   subtle stroke-1.75 check marker. Chosen over the previous colored em-dash
 *   so the list reads as a quiet feature row instead of a colored fence.
 * - When neither description nor highlights are present, render `fallbackText`.
 *
 * `description` is HTML produced by the admin's TipTap rich-text editor. Legacy
 * plain-text descriptions are HTML-safe (just escaped text without tags) and
 * render identically. Rich-text styling lives in `.aien-rich-text` in
 * `src/styles/global.css`.
 */
interface Props {
  categoryName: string;
  description: string;
  highlights: string[];
  fallbackText: string;
}

const { description, highlights, fallbackText } = Astro.props as Props;

const hasDescription = description.trim().length > 0;
const hasHighlights = highlights.length > 0;
---

{
  hasDescription || hasHighlights ? (
    <section class="mb-12 space-y-10">
      {hasDescription && (
        <div>
          <p class="font-sans text-label-caps text-on-surface-variant mb-4">About the collection</p>
          <div class="aien-rich-text font-body-md text-on-surface-variant" set:html={description} />
        </div>
      )}
      {hasHighlights && (
        <div>
          <p class="font-sans text-label-caps text-on-surface-variant mb-4">Feature highlights</p>
          <ul class="grid gap-x-8 gap-y-3 md:grid-cols-2">
            {highlights.map((h) => (
              <li class="flex items-start gap-3 font-body-md text-on-surface-variant">
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="mt-1 h-3.5 w-3.5 shrink-0"
                >
                  <path d="M5 13l4 4L19 7" />
                </svg>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  ) : (
    <section class="mb-12">
      <p class="font-body-lg text-on-surface-variant">{fallbackText}</p>
    </section>
  )
}
